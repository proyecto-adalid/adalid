#setGlobalVariables()
REM la variable DATE_COMMAND_FORMAT especifica el formato de fecha
REM su valor debe corresponder al formato de fecha de la configuración regional de windows
REM el valor debe ser DMY (dia, mes y ańo), MDY (mes, dia y ańo) o YMD (ańo, mes y dia)
set DATE_COMMAND_FORMAT=DMY
set EEAS=$targetApplicationServer
set DBMS=$targetDatabaseServer

