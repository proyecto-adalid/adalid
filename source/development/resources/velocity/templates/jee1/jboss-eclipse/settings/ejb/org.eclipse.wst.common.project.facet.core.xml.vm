    #set($jbossRuntime = 'JBoss 7.1 Runtime')
#else
    #set($jbossRuntime = 'WildFly 9.0 Runtime')
#end
<?xml version="1.0" encoding="UTF-8"?>
<faceted-project>
    <runtime name="${jbossRuntime}"/>
