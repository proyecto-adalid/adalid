            maestro.putEnvironmentVariable(VERSION_JAVA, "1.8.0_25");
            maestro.putEnvironmentVariable(VERSION_GLASSFISH, "4.1");
//          maestro.putEnvironmentVariable(VERSION_JBOSS, "9.0.0.Final");
